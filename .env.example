P24_MERCHANT_ID=
P24_POS_ID=
P24_CRC_KEY=
P24_API_KEY=
P24_ORDER_KEY=
P24_SANDBOX=true

# PayU REST API (do strony /ai-avatar-pl)
# Uzyskaj te wartości w PayU Management Panel po założeniu punktu płatności (POS)
# Sandbox: https://secure.snd.payu.com/cp/  |  Produkcja: https://secure.payu.com/cp/
PAYU_POS_ID=
PAYU_CLIENT_ID=
PAYU_CLIENT_SECRET=
PAYU_SECOND_KEY=
PAYU_SANDBOX=true

# Wspólne dla obu integracji
NEXT_PUBLIC_SITE_URL=https://prokopov-ai.vercel.app

# Telegram lead notifications (admin DMs)
# Bot token from @BotFather (shared with Zenedu — only sendMessage is used,
# never setWebhook/getUpdates so Zenedu's webhook stays intact)
TELEGRAM_BOT_TOKEN=
# Comma-separated numeric chat IDs of admins, e.g. "513664953,111111111"
TELEGRAM_ADMIN_CHAT_IDS=
